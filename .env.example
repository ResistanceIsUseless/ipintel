# ipintel configuration
# Copy to .env and fill in your values

# --- Threat Intelligence API Keys (all optional) ---

# GreyNoise API key (community or enterprise)
GREYNOISE_API_KEY=

# AbuseIPDB API key
ABUSEIPDB_API_KEY=

# Shodan API key
SHODAN_API_KEY=

# VirusTotal API key (free: 4 req/min, 500 req/day)
VIRUSTOTAL_API_KEY=

# --- Azure Tenant Lookup ---
# Set AZURE_SUBSCRIPTION_ID to enable querying your Azure subscription
# for public IP ownership. Auth uses DefaultAzureCredential:
# 1. az login (easiest for local dev)
# 2. Environment variables (AZURE_TENANT_ID, AZURE_CLIENT_ID, AZURE_CLIENT_SECRET)
# 3. Managed identity (in Azure)
AZURE_SUBSCRIPTION_ID=
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# --- AWS Tenant Lookup ---
# Auth uses the default credential chain:
# 1. Environment variables (AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY)
# 2. ~/.aws/credentials profile
# 3. Instance role (in AWS)
# Set AWS_TENANT_ENABLED=true if using profile/instance auth without explicit keys.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_TENANT_ENABLED=true
