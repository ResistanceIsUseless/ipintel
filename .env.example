# ipintel configuration
# Copy to .env and fill in your values

# GreyNoise API key (community or enterprise)
GREYNOISE_API_KEY=

# AbuseIPDB API key
ABUSEIPDB_API_KEY=

# Shodan API key
SHODAN_API_KEY=

# Phase 2: Azure credentials (or use az login)
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# Phase 2: AWS credentials (or use ~/.aws/credentials)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
