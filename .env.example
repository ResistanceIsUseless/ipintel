# ipintel configuration
# Copy to .env and fill in your values

# --- Threat Intelligence API Keys (all optional) ---

# GreyNoise API key (community or enterprise)
GREYNOISE_API_KEY=

# AbuseIPDB API key
ABUSEIPDB_API_KEY=

# Shodan API key
SHODAN_API_KEY=

# VirusTotal API key (free: 4 req/min, 500 req/day)
VIRUSTOTAL_API_KEY=

# --- Azure Tenant Lookup ---
# Uses Azure Resource Graph to search ALL subscriptions your credential can access.
# Auth uses DefaultAzureCredential:
#   1. az login (easiest for local dev)
#   2. Environment variables (AZURE_TENANT_ID, AZURE_CLIENT_ID, AZURE_CLIENT_SECRET)
#   3. Managed identity (in Azure)
# Set any of these to enable:
AZURE_TENANT_ENABLED=true
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# --- AWS Tenant Lookup ---
# Searches ALL regions concurrently for the IP across your AWS accounts.
#
# Enable with any of: AWS_TENANT_ENABLED, AWS_SSO_ROLE, AWS_ACCESS_KEY_ID, AWS_PROFILE, or AWS_PROFILES
AWS_TENANT_ENABLED=true
#
# --- SSO mode (recommended) ---
# Discovers all org accounts via AWS SSO and assumes a role in each.
# Requires an active SSO session (aws sso login --profile <your-sso-profile>).
# AWS_SSO_ROLE=ReadOnlyAccess
# AWS_SSO_REGION=us-east-1
#
# --- Profile mode (fallback) ---
# Uses explicit AWS CLI profiles from ~/.aws/credentials or ~/.aws/config.
# AWS_PROFILES=default,prod-account,staging-account
# AWS_PROFILE=default
#
# Limit regions to search (comma-separated). Omit to search all major regions.
# AWS_REGIONS=us-east-1,us-west-2,eu-west-1
